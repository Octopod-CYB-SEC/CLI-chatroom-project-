<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">

  <style>
    *{
      font-family: Arial, Helvetica, sans-serif;
    }

    input{
      padding:10px;
      margin:10px;
    }

    #Q1{
      padding:10px;
    }

    div{
      outline:solid 1px black;
      text-align:center;
      width:500px;
      height:400px;
      margin:auto;
      margin-top:100px;
    }

    h1{
      text-align:center;
    }

    #submit{
      border:solid black 2px;
      border-radius:5px;
      background-color:white;
      color:black;
      transition-duration:0.5s;
      padding:10px 20px;
    }

    #submit:hover{
      background-color:red;
      color:white;
    }
  </style>
</head>

<body>

<h1>Culture day form</h1>

<div>
  <h1>Fill in the form</h1>

  <form action="/submit-student" method="POST">

    <label for="Q1">Enter your name:</label><br>
    <input type="text" id="Q1" name="fullname"
      placeholder="Enter your whole name:" required><br>

    <label for="Q2">Enter your year group:</label><br>
    <input type="text" id="Q2" name="yearGroup"
      placeholder="What year are you in?" required><br>

    <label for="Q3">Form group:</label><br>
    <input type="text" id="Q3" name="formGroup"
      placeholder="Enter your form group:" required><br>

    <button type="submit" id="submit">
      Submit
    </button>

  </form>
</div>

</body>
</html>
