<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport"
      content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />


<title>QR Scanner</title>


<script src="https://cdnjs.cloudflare.com/ajax/libs/html5-qrcode/2.3.8/html5-qrcode.min.js"></script>


<style>
/* ---------- RESET ---------- */


*{
  margin:0;
  padding:0;
  box-sizing:border-box;
}


/* ---------- BODY ---------- */


body{
  background:#ffffff;
  color:#f0f0f0;
  font-family:Arial, Helvetica, sans-serif;


  min-height:100vh;


  display:flex;
  flex-direction:column;
  align-items:center;


  padding:24px 16px;
  gap:20px;
}


/* ---------- TITLE ---------- */


h1{
  font-size:1rem;
  letter-spacing:.25em;
  text-transform:uppercase;
  color:#000;
  font-weight:400;
}


/* ---------- HELP BUTTON ---------- */


#openBtn{
  position:fixed;
  top:18px;
  right:18px;


  width:38px;
  height:38px;


  border:none;
  border-radius:50%;


  background:#111;
  color:#fff;


  font-size:1rem;
  cursor:pointer;


  transition:.2s;
}


#openBtn:hover{
  background:#00e5ff;
  color:#000;
}


/* ---------- SCANNER ---------- */


#scanner-box{
  width:100%;
  max-width:380px;
  aspect-ratio:1/1;


  position:relative;
  overflow:hidden;


  background:#111;
  border:1px solid #222;
  border-radius:14px;
}


#reader{
  width:100% !important;
  height:100% !important;
}


#reader video{
  width:100% !important;
  height:100% !important;
  object-fit:cover !important;
  transform:scaleX(-1);
}


/* hide default html5-qrcode UI */


#reader img,
#reader__dashboard,
#reader__dashboard_section,
#reader__scan_region img{
  display:none !important;
}


#reader__scan_region{
  position:absolute !important;
  inset:0 !important;
  border:none !important;
}


/* ---------- SCAN DECORATION ---------- */


.corner{
  position:absolute;


  width:28px;
  height:28px;


  border-color:#00e5ff;
  border-style:solid;
  border-width:0;


  pointer-events:none;
  z-index:5;
}


.corner.tl{
  top:16px;
  left:16px;
  border-top-width:3px;
  border-left-width:3px;
}


.corner.tr{
  top:16px;
  right:16px;
  border-top-width:3px;
  border-right-width:3px;
}


.corner.bl{
  bottom:16px;
  left:16px;
  border-bottom-width:3px;
  border-left-width:3px;
}


.corner.br{
  bottom:16px;
  right:16px;
  border-bottom-width:3px;
  border-right-width:3px;
}


.scan-line{
  position:absolute;
  left:16px;
  right:16px;


  height:2px;


  background:
    linear-gradient(
      90deg,
      transparent,
      #00e5ff,
      transparent
    );


  animation:scan 2.5s ease-in-out infinite;
}


@keyframes scan{
  0%{ top:20%; }
  50%{ top:80%; }
  100%{ top:20%; }
}


/* ---------- STATUS ---------- */


#status{
  font-size:.75rem;
  letter-spacing:.1em;
  text-transform:uppercase;
  color:#666;
}


#status.active{
  color:#00e5ff;
}


#status.error{
  color:#ff4d4d;
}


/* ---------- RESULT CARD ---------- */


#result-card{
  width:100%;
  max-width:380px;


  display:none;


  background:#222;
  border:1px solid #222;
  border-radius:12px;


  padding:18px;
}


#result-card.visible{
  display:block;
  animation:pop .25s ease;
}


@keyframes pop{
  from{
    transform:scale(.96);
    opacity:0;
  }


  to{
    transform:scale(1);
    opacity:1;
  }
}


#result-label{
  font-size:.65rem;
  letter-spacing:.2em;
  text-transform:uppercase;


  color:#00e5ff;


  margin-bottom:10px;
}


#result-text{
  color:#f0f0f0;
  line-height:1.5;
  word-break:break-word;
}


#result-text a{
  color:#00e5ff;
}


/* ---------- COPY BUTTON ---------- */


#copy-btn{
  margin-top:16px;


  padding:8px 16px;


  border:1px solid #333;
  border-radius:6px;


  background:none;
  color:#888;


  font-size:.7rem;
  letter-spacing:.15em;
  text-transform:uppercase;


  cursor:pointer;
  transition:.2s;
}


#copy-btn:hover{
  border-color:#00e5ff;
  color:#00e5ff;
}


/* ---------- MODAL ---------- */


.modal-overlay{
  position:fixed;
  inset:0;


  display:none;
  place-items:center;


  background:rgba(0, 0, 0, 0.55);
  backdrop-filter:blur(3px);


  z-index:100;
}


.modal-overlay.show{
  display:grid;
}


.modal-box{
  position:relative;


  width:90%;
  max-width:380px;


  padding:24px;


  border-radius:14px;


  background:#ffffff;
  border:1px solid #222;


  color:#000000;


  animation:pop .2s ease;
}


.modal-box h3{
  margin-bottom:12px;
  color:#000000;
}


.modal-box p{
  line-height:1.6;
  color:#ccc;
}


.modal-close{
  position:absolute;
  top:10px;
  right:14px;


  border:none;
  background:none;


  color:#888;
  font-size:24px;


  cursor:pointer;
}


.modal-close:hover{
  color:#fff;
}


h1 {
  color: #000000;
}


input {
  cursor:pointer; width:20px; height:20px
}


label {
  color: #000000; padding-left: 12px;
}


#copy-btn:hover{
  border-color:#00e5ff;
  color:#00e5ff;
}


#form-submit-btn{
   border:1px solid #333;
  border-radius:6px;


  width:auto;
  height:auto;
  padding:5px 20px;


  background:none;
  color:#888;


  font: size 10px;rem; 
  letter-spacing:.15em;
  text-transform:uppercase;


  cursor:pointer;
  transition:.2s;
}


/* ---------- RESTART BUTTON ---------- */


#restartBtn{
  width: 200px; height: 25px;
  border-radius: 6px;
  background:#111;
  color:#fff;
  display:block;
  margin-right: auto;
}


#restartBtn:hover{
  background:#00e5ff;
  color:#000;
  transition-duration:100ms
}


#restartBtn:disabled{
  opacity: 0.4;
  cursor: not-allowed;
}


.list_
</style>
</head>


<body>


<button id="openBtn">?</button>


<button id="restartBtn">Restart Scanner</button>


<h1>QR Code Reader</h1>


<div id="scanner-box">


  <div id="reader"></div>


  <div class="corner tl"></div>
  <div class="corner tr"></div>
  <div class="corner bl"></div>
  <div class="corner br"></div>


  <div class="scan-line"></div>


</div>


<div id="status">Starting camera…</div>


<div id="result-card">


  <div id="result-label">Scanned Result</div>


  <div id="result-text"></div>


  <button id="copy-btn">Copy</button>


</div>


<!-- MODAL -->


<div id="modal" class="modal-overlay">


  <div class="modal-box">


    <button id="closeBtn" class="modal-close"></button>


    <h3>How to use</h3>


    <ul id="How_list">
      <li class="list_item">First allow the camera have access</li>
      <li class="list_item">Then scan the QR code clearly and keep your phone steady</li>
      <li class="list_item">Make sure your phone camera is clean</li>
      <li class="list_item">After the scan you'll get a pop up below</li>
      <li class="list_item">Either they'll be accepted and rejected with a reason aswell</li>
      <li class="list_item">If the code doesn't work as intended refresh the site</li>
    </ul>


  </div>


</div>
<div>
   <h1 style="text-decoration: underline;">Activity Form</h1><br>
   <form>
    <input type="checkbox" class="Activities">
    <label  for="Activity 1">Activity 1</label><br>
    <input type="checkbox" class="Activities">
    <label for="Activity 2">Activity 2</label><br>
    <input type="checkbox" class="Activities">
    <label for="Activity 3">Activity 3</label><br>
    <input type="checkbox" class="Activities">
    <label for="Activity 4">Activity 4</label><br>
    <input type="submit" id="form-submit-btn" value="Submit!">
   </form>
<div>






<script>
const statusEl = document.getElementById("status");
const resultCard = document.getElementById("result-card");
const resultText = document.getElementById("result-text");
const copyBtn = document.getElementById("copy-btn");


const modal = document.getElementById("modal");
const openBtn = document.getElementById("openBtn");
const closeBtn = document.getElementById("closeBtn");
const restartBtn = document.getElementById("restartBtn")


let lastResult = "";
let qrToken = "";


/* ---------- QR SCANNER ---------- */


function onScanSuccess(decodedText){


  if(decodedText === lastResult) return;


  lastResult = decodedText;


  // Send QR data to Django
  fetch("/api/qr-scan/", {
      method: "POST",
      headers: {
          "Content-Type": "application/json",
          "X-CSRFToken": getCSRFToken()
      },
      body: JSON.stringify({
          qr_data: decodedText
      })
  })
  .then(response => response.json())
  .then(data => {
      console.log("Server response:", data);
  })
  .catch(error => {
      console.error(error);
  });


  if(navigator.vibrate){
    navigator.vibrate(100);
  }


  let display;


  try{
    const url = new URL(decodedText);


    if(url.protocol === "http:" || url.protocol === "https:"){
      display =
        `<a href="${decodedText}"
            target="_blank"
            rel="noopener">
            ${decodedText}
         </a>`;
    }else{
      display = decodedText;
    }


  }catch{
    display = decodedText;
  }


  resultText.innerHTML = display;


  resultCard.classList.add("visible");


  statusEl.textContent = "Code detected";
  statusEl.className = "active";


  copyBtn.textContent = "Copy";
}


function getCSRFToken() {
    return document.cookie
        .split("; ")
        .find(row => row.startsWith("csrftoken="))
        ?.split("=")[1];
}


function onScanError(){


}


/* ---------- COPY ---------- */


copyBtn.addEventListener("click", async () => {


  try{
    await navigator.clipboard.writeText(lastResult);


    copyBtn.textContent = "Copied!";


    setTimeout(() => {
      copyBtn.textContent = "Copy";
    }, 1500);


  }catch(err){
    console.error(err);
  }


});


/* ---------- CAMERA ---------- */


const html5QrCode = new Html5Qrcode("reader");


html5QrCode.start(
  { facingMode:"environment" },
  {
    fps:10,
    qrbox:{ width:220, height:220 },
    aspectRatio:1
  },
  onScanSuccess,
  onScanError
)


.then(() => {


  statusEl.textContent = "Scanning…";
  statusEl.className = "active";


})


.catch(err => {


  statusEl.textContent = "Camera access denied";
  statusEl.className = "error";


  console.error(err);


});


/* ---------- MODAL ---------- */


function openModal(){
  modal.classList.add("show");
}


function closeModal(){
  modal.classList.remove("show");
}


openBtn.addEventListener("click", openModal);


closeBtn.addEventListener("click", closeModal);


restartBtn.addEventListener("click", async () => {


restartBtn.disabled = true;  
 
try{
  await html5QrCode.stop();
 
  lastResult="";
  resultCard.classList.remove("visible");


  await html5QrCode.start(
    { facingMode:'environment' },
    {
      fps:10,
      qrbox:{width:220, height:220},
      aspectRatio:1
    },
    onScanSuccess,
    onScanError


  );


  statusEl.textContent="Scanning...";
  statusEl.className= "active";


}catch(err){
  console.error(err);
  statusEl.textContent="Restart failed";
  statusEl.className="error";
 
} finally{
  await new Promise(resolve => setTimeout(resolve, 300));
  restartBtn.disabled = false;
}


});


modal.addEventListener("click", e => {
  if(e.target === modal){
    closeModal();
  }
});


document.addEventListener("keydown", e => {
  if(e.key === "Escape"){
    closeModal();
  }
});
</script>


</body>
</html>

